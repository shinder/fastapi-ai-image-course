# 應用設定
APP_NAME=fastapi-ai-image
DEBUG=true

# PostgreSQL
# DATABASE_URL=postgresql+psycopg://pguser:pgUser567@localhost:5432/shin02
# SQLite（開發環境使用，生產環境建議使用 PostgreSQL）
DATABASE_URL=sqlite:///./app.db

# Redis
REDIS_URL=redis://localhost:6379/0

# MongoDB（單元九 補充教材）
MONGO_URL=mongodb://localhost:27017
MONGO_DB=ai_image_db

# Ollama（單元 5.5 視覺模型）
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=gemma3:4b

# OpenAI（選用，僅單元 5.6 影像生成需要）
OPENAI_API_KEY=

# 上傳目錄
UPLOAD_DIR=./uploads
